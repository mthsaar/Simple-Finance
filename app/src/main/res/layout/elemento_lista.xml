<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:contentDescription="@string/input_icon"
        android:src="@drawable/outline_input_circle_24"
        app:layout_constraintBottom_toBottomOf="@+id/tvDataElementoLista"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvNomeElementoLista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:textSize="20sp"
        app:layout_constraintStart_toEndOf="@+id/imageView"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Salário" />

    <TextView
        android:id="@+id/tvValorElementoLista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="@+id/tvNomeElementoLista"
        app:layout_constraintTop_toBottomOf="@+id/tvNomeElementoLista"
        tools:text="20.000,00" />

    <TextView
        android:id="@+id/tvTipoDeLancamentoLista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@id/tvValorElementoLista"
        app:layout_constraintTop_toBottomOf="@+id/tvNomeElementoLista"
        tools:text="Crédito" />

    <TextView
        android:id="@+id/tvDataElementoLista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="@+id/tvNomeElementoLista"
        app:layout_constraintTop_toBottomOf="@+id/tvValorElementoLista"
        tools:text="02/09/26" />

    <ImageButton
        android:id="@+id/btEditarElementoLista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/edit_icon"
        app:layout_constraintBottom_toBottomOf="@+id/tvDataElementoLista"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvNomeElementoLista"
        app:srcCompat="@drawable/ic_menu_edit" />

</androidx.constraintlayout.widget.ConstraintLayout>